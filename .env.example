# ===========================================
# 期末资料共享平台 - 环境变量配置
# ===========================================
# 复制此文件为 .env.local 并填入真实值
# cp .env.example .env.local
# ===========================================

# ----------------
# 腾讯云 PostgreSQL 数据库配置（必需）
# ----------------
# 直连地址，例如腾讯云 PostgreSQL / TDSQL for PostgreSQL
DATABASE_URL=postgresql://postgres:password@host:5432/postgres

# 如果你更习惯拆分字段，也可以保留这些变量
PGHOST=host
PGPORT=5432
PGUSER=postgres
PGPASSWORD=password
PGDATABASE=postgres
PGSSLMODE=require
PGCHANNELBINDING=require

# ----------------
# 腾讯云 COS 对象存储配置（必需）
# ----------------
# 腾讯云 API 密钥 ID（在腾讯云控制台 -> 访问管理 -> API密钥 获取）
COS_SECRET_ID=your-secret-id

# 腾讯云 API 密钥 Key
COS_SECRET_KEY=your-secret-key

# COS 存储桶名称
COS_BUCKET_NAME=your-bucket-name

# COS 地域，如：ap-guangzhou, ap-shanghai, ap-beijing
COS_REGION=ap-guangzhou

# ----------------
# LLM AI 配置（可选，用于智能分类）
# ----------------
# LLM API 密钥
LLM_API_KEY=your-llm-api-key

# LLM API 地址
# 豆包：https://ark.cn-beijing.volces.com/api/v3
# DeepSeek：https://api.deepseek.com
# Kimi：https://api.moonshot.cn/v1
LLM_BASE_URL=https://api.moonshot.cn/v1

# 模型名称
LLM_MODEL=moonshot-v1-8k

# ----------------
# 项目域名配置（本地开发可选）
# ----------------
# 项目对外访问域名（用于生成文件预览 URL）
COZE_PROJECT_DOMAIN_DEFAULT=http://localhost:4000
